{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/assets/(.*)", "dest": "/front/assets/$1" },
    { "src": "/([a-z]+\\.html)$", "dest": "/front/$1" },
    { "src": "/", "dest": "/front/login.html" }
  ]
}
