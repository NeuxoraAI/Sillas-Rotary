{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "front/**"
      }
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/(backend|tests|scripts)/(.*)",
      "status": 404
    },
    {
      "src": "/(.*)\\.sql$",
      "status": 404
    },
    {
      "src": "/(.*)\\.(py|env|toml|ini)$",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
